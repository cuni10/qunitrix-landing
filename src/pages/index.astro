---
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Qunitrix</title>
    <link rel="icon" type="image/svg+xml" href="/Logo_V5.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <svg class="svg-filters" aria-hidden="true">
      <filter id="glass-distortion" x="0%" y="0%" width="100%" height="100%" filterUnits="objectBoundingBox">
        <feTurbulence type="fractalNoise" baseFrequency="0.01 0.01" numOctaves="1" seed="5" result="turbulence" />
        <feComponentTransfer in="turbulence" result="mapped">
          <feFuncR type="gamma" amplitude="1" exponent="10" offset="0.5" />
          <feFuncG type="gamma" amplitude="0" exponent="1" offset="0" />
          <feFuncB type="gamma" amplitude="0" exponent="1" offset="0.5" />
        </feComponentTransfer>
        <feGaussianBlur in="turbulence" stdDeviation="3" result="softMap" />
        <feDisplacementMap in="SourceGraphic" in2="softMap" scale="150" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </svg>

    <video class="bg-video" autoplay muted loop playsinline>
      <source src="/bg.webm" type="video/webm" />
    </video>

    <nav class="dock">
      <div class="dock-glass">
        <div class="glass-effect"></div>
        <div class="glass-tint"></div>
        <div class="glass-shine"></div>
        <div class="glass-content dock-items">
          <button class="dock-item active" data-view="inicio">Inicio</button>
          <button class="dock-item" data-view="proyectos">Proyectos</button>
        </div>
      </div>
    </nav>

    <div class="main-container">
      <div class="glass-panel">
        <div class="glass-effect"></div>
        <div class="glass-tint"></div>
        <div class="glass-shine"></div>
        <div class="glass-content">

          <div id="view-inicio" class="view active">
            <div class="logo-wrapper">
              <div class="logo-blur"></div>
              <img src="/Logo_V5.svg" alt="Qunitrix" class="logo-img" id="logo-clickable" width="300" draggable="false" />
            </div>
            <p class="subtitle">Software</p>
          </div>

          <div id="view-proyectos" class="view">
            <h2 class="section-title">Proyectos</h2>
            <a href="https://stockapp.qunitrix.com" class="project-card" target="_blank" rel="noopener">
              <img src="/faviconStockApp.ico" alt="" class="project-icon" />
              <h3>StockApp</h3>
            </a>
          </div>

        </div>
      </div>
    </div>

    <script>
      const items = document.querySelectorAll(".dock-item");
      const views = document.querySelectorAll(".view");
      items.forEach((item) => {
        item.addEventListener("click", () => {
          const target = item.getAttribute("data-view");

          items.forEach((i) => i.classList.remove("active"));
          item.classList.add("active");

          views.forEach((v) => v.classList.remove("active"));
          document.getElementById("view-" + target).classList.add("active");
        });
      });

    </script>
  </body>
</html>
